generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id        String     @id @default(cuid()) 
  email     String     @unique
  name      String
  password  String

  records   Record[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
} 

model Record {
  id                String     @id @default(cuid())
  description      String?
  amount            Decimal
  date              DateTime   @default(now())
  category          Types      @default(EXPENSE)

  userId            String
  user              User       @relation(fields: [userId], references: [id])

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

}

enum Types {
  INCOME
  EXPENSE
  INVESTMENT
}